{
  "_comment": "Copy to your config dir's config.json (~/.config/picopi/config.json). Roles -> alias + thinking (+ timeout); each alias is an ordered list of provider/id models, first with a working key wins.",

  "orchestrator": { "model": "pro", "thinking": "high" },

  "agents": {
    "planner":      { "model": "pro",   "thinking": "xhigh",  "timeout": 600 },
    "explorer":     { "model": "flash", "thinking": "low",    "timeout": 300 },
    "fixer":        { "model": "flash", "thinking": "medium", "timeout": 180 },
    "auditor":      { "model": "pro",   "thinking": "high",   "timeout": 300 },
    "web-searcher": { "model": "flash", "thinking": "low",    "timeout": 300 }
  },

  "aliases": {
    "pro":        [ "openrouter/anthropic/claude-opus-4",   "anthropic/claude-opus-4-5",   "google/gemini-2.5-pro" ],
    "flash":      [ "openrouter/anthropic/claude-sonnet-4", "anthropic/claude-sonnet-4-5", "google/gemini-2.5-flash" ]
    // Presets: override chains at runtime via /preset by naming them alias@preset.
    // Example:
    // "pro@fast":   [ "google/gemini-2.5-flash" ],
    // "pro@local":  [ "ollama/llama3.3:70b" ],
    // "flash@fast": [ "google/gemini-2.5-flash" ]
  },

  "compaction": { "model": "flash" },

  "webSearch": { "provider": "auto" }
}
