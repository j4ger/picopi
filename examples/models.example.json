      "apiKey": "$OPENROUTER_API_KEY",
      "models": [
        { "id": "anthropic/claude-opus-4", "reasoning": true },
        { "id": "anthropic/claude-sonnet-4", "reasoning": true }
      ]
    }
  }
}
