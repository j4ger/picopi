{
  "_comment": "=== PICOPI CONFIG (edit this) === Agents reference LABELS that map to explicit provider/modelname fallback chains. NEVER commit or share.",

  "orchestrator": {
    "model": "quick",
    "thinking": "high"
  },

  "agents": {
    "planner":  { "model": "pro",   "thinking": "xhigh", "timeout": 600 },
    "explorer": { "model": "lite",  "thinking": "off",   "timeout": 300 },
    "fixer":    { "model": "quick", "thinking": "off",   "timeout": 180 },
    "auditor":  { "model": "pro",   "thinking": "high",  "timeout": 300 }
  },

  "fallbacks": {
    "quick": ["deepseek/deepseek-v4-flash",       "sensenova/deepseek-v4-flash"],
    "pro":   ["deepseek/deepseek-v4-pro",         "sensenova/deepseek-v4-pro"],
    "lite":  ["sensenova/sensenova-6.7-flash-lite", "deepseek/deepseek-v4-flash"]
  },

  "providers": {
    "deepseek": {
      "baseUrl": "https://api.deepseek.com",
      "api": "openai-completions",
      "key": "YOUR_DEEPSEEK_KEY_HERE"
    },
    "sensenova": {
      "baseUrl": "https://token.sensenova.cn/v1",
      "api": "openai-completions",
      "key": "YOUR_SENSENOVA_KEY_HERE"
    }
  },

  "compaction": {
    "_comment": "Optional: use a cheaper model for context summarization. Falls back to session model if not set.",
    "model": "lite"
  }
}
