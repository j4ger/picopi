{
  "name": "picopi",
  "version": "0.1.0",
  "description": "A batteries-included pi agent: web access, opencode-style undo, todos, slim multi-agent, and role/fallback model resolution — packaged with Nix.",
  "keywords": ["pi-package", "pi", "coding-agent"],
  "license": "MIT",
  "type": "module",
  "pi": {
    "extensions": ["./src"],
    "agents": ["./agent/agents"],
    "prompts": ["./agent/prompts"],
    "themes": ["./agent/themes"]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
